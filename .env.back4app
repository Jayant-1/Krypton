# ── .env.back4app ────────────────────────────────────────────────────────────
# This is the environment configuration for back4app production deployment
# Do NOT commit this to version control
# Instead, set these variables in back4app Dashboard → Settings → Environment Variables

# ── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Semantic Scholar (optional) ───────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=

# ── Cache Settings ────────────────────────────────────────────────────────────
CACHE_TTL_MINUTES=30
CACHE_DIR=cache

# ── Search Settings ───────────────────────────────────────────────────────────
MAX_RESULTS_DEFAULT=20
MAX_RESULTS_LIMIT=50

# ── AI Model ──────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash

# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_VERSION=1.0.0

# ── Authentication (JWT) ──────────────────────────────────────────────────────
# 🔒 CRITICAL SECURITY: This must be a unique key for production
# Generate with: openssl rand -hex 32
# Current key: 3bf13a49f95767c884734a935c87eb7e6ad8775d569059d55200b63f20e8f26d
SECRET_KEY=3bf13a49f95767c884734a935c87eb7e6ad8775d569059d55200b63f20e8f26d

# ── CORS ───────────────────────────────────────────────────────────────────────
# 🔒 CRITICAL: Set to your Vercel frontend domain(s)
# Your Vercel domain will be something like: https://yourapp.vercel.app
# Update this to match your actual Vercel URL
ALLOWED_ORIGINS=https://yourapp.vercel.app,https://www.yourapp.vercel.app

# ── Database (Managed by back4app) ────────────────────────────────────────────
# back4app provides DATABASE_URL automatically (MongoDB via Parse Server)
# You don't need to set this - back4app sets it for you
# It will look like: mongodb+srv://user:pass@...
# DATABASE_URL is auto-injected by back4app
