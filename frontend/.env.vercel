# Frontend environment for Vercel production build
# Set in: Vercel Dashboard → Project Settings → Environment Variables

# ── API Base URL ──────────────────────────────────────────────────────────────
# CRITICAL: This must point to your back4app backend domain
# Replace 'yourapp' with your actual back4app domain name
# Examples:
#   - https://myapp.back4app.io
#   - https://research-agent.back4app.io
# DO NOT use http:// (HTTPS only for production)
VITE_API_BASE_URL=https://yourapp.back4app.io
