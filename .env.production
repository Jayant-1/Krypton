# ── Production Configuration ──────────────────────────────────────────────────

# ── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Semantic Scholar (optional) ───────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=

# ── Cache Settings ────────────────────────────────────────────────────────────
CACHE_TTL_MINUTES=30
CACHE_DIR=cache

# ── Search Settings ───────────────────────────────────────────────────────────
MAX_RESULTS_DEFAULT=20
MAX_RESULTS_LIMIT=50

# ── AI Model ──────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash

# ── Server ────────────────────────────────────────────────────────────────────
# IMPORTANT: Set to 'production' in production environment
APP_ENV=production

# ── Authentication (JWT) ──────────────────────────────────────────────────────
# 🔒 CRITICAL SECURITY: Generate a unique key for production
# Run: openssl rand -hex 32
# DO NOT reuse development keys or hardcoded values
SECRET_KEY=3bf13a49f95767c884734a935c87eb7e6ad8775d569059d55200b63f20e8f26d
# ── CORS ───────────────────────────────────────────────────────────────────────
# 🔒 CRITICAL: Set to your Vercel frontend domain(s)
# If deploying to Vercel, use: https://yourapp.vercel.app
# This MUST match your frontend domain or CORS will block requests - browser will show CORS error
ALLOWED_ORIGINS=https://yourapp.vercel.app
