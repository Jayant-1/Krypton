# ── Google Gemini ────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Semantic Scholar (optional) ───────────────────────────────────────────────
# Sign up at https://www.semanticscholar.org/product/api
# Leave blank to use the unauthenticated tier (lower rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# ── Cache Settings ────────────────────────────────────────────────────────────
CACHE_TTL_MINUTES=30
CACHE_DIR=cache

# ── Search Settings ───────────────────────────────────────────────────────────
MAX_RESULTS_DEFAULT=20
MAX_RESULTS_LIMIT=50

# ── AI Model ──────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash

# ── Server ────────────────────────────────────────────────────────────────────
# Set to 'production' when deployed to production environment
APP_ENV=development

# ── Authentication (JWT) ──────────────────────────────────────────────────────
# 🔒 CRITICAL: In production, generate a strong random key with: openssl rand -hex 32
# Development uses a default insecure key (OK for local testing only)
# Production MUST have a unique, cryptographically-secure secret key
# Example: openssl rand -hex 32 → 3f4e8a9c2b1d5f7e6a3c9b2d1f5e7a8c9b2d1f5e7a8c9b2d1f5e7a8c9b2d1f5
SECRET_KEY=dev-insecure-key-please-change-in-production

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to access this API
# For development: http://localhost:3000,http://localhost:5173
# For production: https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com
# If empty string in production, CORS will block ALL requests (causes app to fail silently)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
